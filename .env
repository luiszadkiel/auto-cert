# ─── auto-cert — variables de entorno ─────────────────────────────────────────
#
# Para uso LOCAL (py main.py aks-only):
#   Si tu cuenta no tiene MFA, AZURE_USERNAME + AZURE_PASSWORD hacen el login
#   automatico. Si tienes MFA, el device-code se dispara igual en la terminal.
#
# Para uso en SERVIDOR / ZABBIX (login completamente automatico):
#   Usar Service Principal (AZURE_CLIENT_ID + AZURE_CLIENT_SECRET).
#   El usuario/password NO funcionan con MFA en un servidor sin browser.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Tenant (ya configurado en el codigo) ─────────────────────────────────────
# AZURE_TENANT_ID=d0b50d16-a5e9-4cf2-a9d0-4733a3470110

# ── Usuario Azure personal (funciona solo si NO tienes MFA activo) ────────────
# ADVERTENCIA: si BHD aplica MFA, estas variables se ignoran y se usa device-code
AZURE_USERNAME=luis_duran@bhd.com.do
AZURE_PASSWORD=uran01@#ygvuhb*

# ── Service Principal (para Zabbix / automatizacion) ─────────────────────────
# Rellenar cuando Freddy/Seguridad entreguen las credenciales:
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=tu-client-secret-aqui

# ── Tu Object ID personal (para preflight RBAC check) ────────────────────────
# AZURE_ASSIGNEE_ID=5991c772-3256-4113-b62a-d37b40d25ead

# ── Configuracion JKS Update ──────────────────────────────────────────────────
# JKS_UPDATE_APPLY=false
# JKS_UPDATE_PRUNE=false

# ── Fallback password para keystores JKS ─────────────────────────────────────
# JKS_FALLBACK_PASSWORD=12345678
